mixin staffForm(staff, locations, departments, nationalities, isEdit)
  - const isFixed = isEdit ? staff.employmentType === 'Fixed' : (old && old.employmentType === 'Fixed')
  - const selNat   = isEdit ? staff.nationality : (old && old.nationality || '')
  - const selLocId = isEdit ? staff.locationId  : (old && parseInt(old.locationId) || null)
  - const selDeptId= isEdit ? staff.departmentId: (old && parseInt(old.departmentId) || null)
  - const selSubId = isEdit ? staff.subDepartmentId : (old && parseInt(old.subDepartmentId) || null)
  - const selUnitId= isEdit ? staff.unitId : (old && parseInt(old.unitId) || null)

  if errors && errors.length
    .alert.alert-error
      i.fas.fa-exclamation-circle
      ul
        each err in errors
          li= err

  .form-grid

    //- ── Personal Information ────────────────────────────────
    .form-section
      .section-header
        i.fas.fa-id-card
        h3 Personal Information

      .form-row
        .form-group.form-group-sm
          label.form-label Title *
          select.form-input(name="title" required)
            option(value="") —
            each t in ['Mr','Mrs','Ms','Miss']
              option(value=t selected=(isEdit ? staff.title===t : (old && old.title===t)))= t

        .form-group
          label.form-label First Name *
          input.form-input(type="text" name="firstName" required
            value=(isEdit ? staff.firstName : (old && old.firstName || '')))

        .form-group
          label.form-label Middle Name
          input.form-input(type="text" name="middleName"
            value=(isEdit ? staff.middleName || '' : (old && old.middleName || '')))

        .form-group
          label.form-label Last Name *
          input.form-input(type="text" name="lastName" required
            value=(isEdit ? staff.lastName : (old && old.lastName || '')))

      .form-row
        .form-group
          label.form-label Date of Birth *
          input.form-input(type="date" name="dateOfBirth" required
            value=(isEdit ? staff.dateOfBirth : (old && old.dateOfBirth || '')))

        //- ── Nationality with search ─────────────────────────
        .form-group
          label.form-label Nationality *
          .nat-select-wrap
            input.form-input#natSearch(
              type="text"
              placeholder="Search nationality..."
              autocomplete="off"
              value=selNat
              onfocus="openNatDropdown()"
              oninput="filterNats(this.value)"
            )
            input(type="hidden" name="nationality" id="natHidden" value=selNat required)
            .nat-dropdown#natDropdown(style="display:none")
              each nat in nationalities
                .nat-option(
                  onclick=`selectNat('${nat}')`
                  class=(selNat === nat ? 'nat-selected' : '')
                )= nat

    //- ── Employment Information ───────────────────────────────
    .form-section
      .section-header
        i.fas.fa-briefcase
        h3 Employment Information

      .form-row
        .form-group
          label.form-label Date of Employment *
          input.form-input(type="date" name="dateOfEmployment" required
            value=(isEdit ? staff.dateOfEmployment : (old && old.dateOfEmployment || '')))

        .form-group
          label.form-label Employment Type *
          select.form-input#empTypeSelect(name="employmentType" required onchange="toggleFixedFields(this.value)")
            option(value="") Select Type
            each et in ['Fixed','Permanent','Temporary']
              option(value=et selected=(isEdit ? staff.employmentType===et : (old && old.employmentType===et)))= et

        .form-group
          label.form-label Education Level *
          select.form-input(name="educationLevel" required)
            option(value="") Select Level
            each el in ['Unskilled','Certificate','Diploma','Degree','Masters','PHD']
              option(value=el selected=(isEdit ? staff.educationLevel===el : (old && old.educationLevel===el)))= el

      //- Fixed Contract Panel
      .fixed-contract-panel#fixedContractPanel(style=isFixed ? '' : 'display:none')
        .fixed-contract-header
          i.fas.fa-file-contract
          span Fixed Contract Details
        .form-row
          .form-group
            label.form-label Contract Length (months) *
            input.form-input#contractLengthInput(type="number" name="employmentLength"
              min="1" max="240" placeholder="e.g. 12" oninput="calcEndDate()"
              value=(isEdit ? staff.employmentLength || '' : (old && old.employmentLength || '')))
          .form-group
            label.form-label Contract Start Date *
            input.form-input#contractStartInput(type="date" name="contractStartDate"
              oninput="calcEndDate()"
              value=(isEdit ? staff.contractStartDate || '' : (old && old.contractStartDate || '')))
          .form-group
            label.form-label Contract End Date
            .end-date-wrap
              input.form-input#contractEndDisplay(type="date" name="contractEndDate" disabled
                value=(isEdit ? staff.contractEndDate || '' : (old && old.contractEndDate || '')))
              .end-date-badge#endDateBadge(style="display:none")

    //- ── Location & Department ───────────────────────────────
    .form-section
      .section-header
        i.fas.fa-map-marker-alt
        h3 Location & Department

      .form-row

        //- Location
        .form-group
          label.form-label Location *
          select.form-input#locationSelect(name="locationId" required onchange="onLocationChange(this)")
            option(value="") — Select Location —
            each loc in locations
              option(value=loc.id selected=(selLocId && selLocId===loc.id))= loc.name

        //- Department — always starts empty, filled by JS after location chosen
        .form-group
          label.form-label Department *
          select.form-input#deptSelect(name="departmentId" required onchange="onDeptChange(this)")
            option(value="") — Select Location First —

        //- Sub-Department
        .form-group
          label.form-label Sub-Department
          select.form-input#subDeptSelect(name="subDepartmentId" onchange="onSubDeptChange(this)" disabled)
            option(value="") — Select Department First —

        //- Unit
        .form-group
          label.form-label Unit
          select.form-input#unitSelect(name="unitId" disabled)
            option(value="") — Select Sub-Dept First —

      .dept-loading#deptLoading(style="display:none")
        i.fas.fa-spinner.fa-spin
        | &nbsp; Loading departments...

  .form-actions
    a.btn.btn-outline(href="/staff") Cancel
    button.btn.btn-primary(type="submit")
      i.fas.fa-save
      | &nbsp;
      = isEdit ? 'Update Staff' : 'Save Staff'

  //- Pass server values to JS safely
  script.
    const SF_SEL_LOC   = !{JSON.stringify(selLocId)};
    const SF_SEL_DEPT  = !{JSON.stringify(selDeptId)};
    const SF_SEL_SUB   = !{JSON.stringify(selSubId)};
    const SF_SEL_UNIT  = !{JSON.stringify(selUnitId)};

    // ─── Nationality searchable dropdown ─────────────────────
    function openNatDropdown() {
      document.getElementById('natDropdown').style.display = 'block';
      filterNats(document.getElementById('natSearch').value);
    }

    function filterNats(q) {
      const drop = document.getElementById('natDropdown');
      drop.style.display = 'block';
      const items = drop.querySelectorAll('.nat-option');
      const ql = q.toLowerCase();
      let visible = 0;
      items.forEach(el => {
        const match = el.textContent.toLowerCase().includes(ql);
        el.style.display = match ? '' : 'none';
        if (match) visible++;
      });
    }

    function selectNat(val) {
      document.getElementById('natSearch').value = val;
      document.getElementById('natHidden').value = val;
      document.getElementById('natDropdown').style.display = 'none';
      // highlight selected
      document.querySelectorAll('.nat-option').forEach(el => {
        el.classList.toggle('nat-selected', el.textContent === val);
      });
    }

    // Close nationality dropdown when clicking outside
    document.addEventListener('click', function(e) {
      const wrap = document.querySelector('.nat-select-wrap');
      if (wrap && !wrap.contains(e.target)) {
        document.getElementById('natDropdown').style.display = 'none';
        // If typed text doesn't match hidden value, clear both
        const search = document.getElementById('natSearch').value;
        const hidden = document.getElementById('natHidden').value;
        if (search !== hidden) {
          document.getElementById('natSearch').value = hidden; // revert to last valid
        }
      }
    });

    // ─── Location → Department (always fetch fresh) ───────────
    function onLocationChange(sel) {
      const locId = parseInt(sel.value);
      resetDept();
      resetSub();
      resetUnit();
      if (!locId) return;

      const deptSel   = document.getElementById('deptSelect');
      const loading   = document.getElementById('deptLoading');
      deptSel.disabled = true;
      loading.style.display = 'flex';

      fetch('/locations/' + locId + '/departments')
        .then(r => r.json())
        .then(depts => {
          deptSel.innerHTML = '<option value="">— Select Department —</option>';
          if (depts.length === 0) {
            deptSel.innerHTML = '<option value="">No departments for this location</option>';
          } else {
            depts.forEach(d => {
              const opt = document.createElement('option');
              opt.value = d.id;
              opt.textContent = d.name;
              // Embed sub-departments as JSON on the option
              const subs = d.subDepartments || d.sub_departments || [];
              opt.dataset.subdepts = JSON.stringify(subs);
              deptSel.appendChild(opt);
            });
          }
          deptSel.disabled = false;
          loading.style.display = 'none';
        })
        .catch(() => {
          deptSel.innerHTML = '<option value="">Error loading departments</option>';
          deptSel.disabled = false;
          loading.style.display = 'none';
        });
    }

    function onDeptChange(sel) {
      resetSub();
      resetUnit();
      const opt  = sel.options[sel.selectedIndex];
      if (!opt || !opt.value) return;
      const subs = JSON.parse(opt.dataset.subdepts || '[]');
      const subSel = document.getElementById('subDeptSelect');
      subSel.innerHTML = '<option value="">— Select Sub-Department —</option>';
      if (subs.length === 0) {
        subSel.innerHTML = '<option value="">No sub-departments</option>';
        subSel.disabled = true;
      } else {
        subs.forEach(s => {
          const o = document.createElement('option');
          o.value = s.id;
          o.textContent = s.name;
          o.dataset.units = JSON.stringify(s.units || []);
          subSel.appendChild(o);
        });
        subSel.disabled = false;
      }
    }

    function onSubDeptChange(sel) {
      resetUnit();
      const opt   = sel.options[sel.selectedIndex];
      if (!opt || !opt.value) return;
      const units = JSON.parse(opt.dataset.units || '[]');
      const unitSel = document.getElementById('unitSelect');
      if (units.length === 0) {
        unitSel.innerHTML = '<option value="">No units</option>';
        unitSel.disabled = true;
      } else {
        unitSel.innerHTML = '<option value="">— Select Unit —</option>';
        units.forEach(u => {
          const o = document.createElement('option');
          o.value = u.id;
          o.textContent = u.name;
          unitSel.appendChild(o);
        });
        unitSel.disabled = false;
      }
    }

    function resetDept() {
      const s = document.getElementById('deptSelect');
      s.innerHTML = '<option value="">— Select Location First —</option>';
      s.disabled = false;
    }
    function resetSub() {
      const s = document.getElementById('subDeptSelect');
      s.innerHTML = '<option value="">— Select Department First —</option>';
      s.disabled = true;
    }
    function resetUnit() {
      const s = document.getElementById('unitSelect');
      s.innerHTML = '<option value="">— Select Sub-Dept First —</option>';
      s.disabled = true;
    }

    // ─── Pre-populate on page load (edit / validation error) ──
    (function init() {
      // Fixed contract
      if (document.getElementById('empTypeSelect').value === 'Fixed') calcEndDate();

      // If no location pre-selected, nothing to do
      if (!SF_SEL_LOC) return;

      // Set location select value
      document.getElementById('locationSelect').value = SF_SEL_LOC;

      // Fetch departments for this location, then set dept, sub, unit
      fetch('/locations/' + SF_SEL_LOC + '/departments')
        .then(r => r.json())
        .then(depts => {
          const deptSel = document.getElementById('deptSelect');
          deptSel.innerHTML = '<option value="">— Select Department —</option>';
          depts.forEach(d => {
            const opt = document.createElement('option');
            opt.value = d.id;
            opt.textContent = d.name;
            const subs = d.subDepartments || d.sub_departments || [];
            opt.dataset.subdepts = JSON.stringify(subs);
            if (SF_SEL_DEPT && parseInt(d.id) === SF_SEL_DEPT) opt.selected = true;
            deptSel.appendChild(opt);
          });
          deptSel.disabled = false;

          // If dept was pre-selected, populate sub-depts
          if (SF_SEL_DEPT) {
            const selOpt = [...deptSel.options].find(o => parseInt(o.value) === SF_SEL_DEPT);
            if (selOpt) {
              const subs = JSON.parse(selOpt.dataset.subdepts || '[]');
              const subSel = document.getElementById('subDeptSelect');
              subSel.innerHTML = '<option value="">— Select Sub-Department —</option>';
              subs.forEach(s => {
                const o = document.createElement('option');
                o.value = s.id;
                o.textContent = s.name;
                o.dataset.units = JSON.stringify(s.units || []);
                if (SF_SEL_SUB && parseInt(s.id) === SF_SEL_SUB) o.selected = true;
                subSel.appendChild(o);
              });
              subSel.disabled = subs.length === 0;

              // If sub-dept was pre-selected, populate units
              if (SF_SEL_SUB) {
                const selSub = [...subSel.options].find(o => parseInt(o.value) === SF_SEL_SUB);
                if (selSub) {
                  const units = JSON.parse(selSub.dataset.units || '[]');
                  const unitSel = document.getElementById('unitSelect');
                  if (units.length > 0) {
                    unitSel.innerHTML = '<option value="">— Select Unit —</option>';
                    units.forEach(u => {
                      const o = document.createElement('option');
                      o.value = u.id;
                      o.textContent = u.name;
                      if (SF_SEL_UNIT && parseInt(u.id) === SF_SEL_UNIT) o.selected = true;
                      unitSel.appendChild(o);
                    });
                    unitSel.disabled = false;
                  }
                }
              }
            }
          }
        });
    })();

    // ─── Fixed contract ───────────────────────────────────────
    function toggleFixedFields(val) {
      document.getElementById('fixedContractPanel').style.display = val === 'Fixed' ? '' : 'none';
      if (val !== 'Fixed') {
        document.getElementById('contractLengthInput').value  = '';
        document.getElementById('contractStartInput').value   = '';
        document.getElementById('contractEndDisplay').value   = '';
        document.getElementById('endDateBadge').style.display = 'none';
      }
    }

    function calcEndDate() {
      const months   = parseInt(document.getElementById('contractLengthInput').value);
      const startVal = document.getElementById('contractStartInput').value;
      const endInput = document.getElementById('contractEndDisplay');
      const badge    = document.getElementById('endDateBadge');
      if (!months || !startVal) { endInput.value = ''; badge.style.display = 'none'; return; }
      const end = new Date(startVal);
      end.setMonth(end.getMonth() + months);
      const yyyy = end.getFullYear();
      const mm   = String(end.getMonth() + 1).padStart(2, '0');
      const dd   = String(end.getDate()).padStart(2, '0');
      endInput.value = `${yyyy}-${mm}-${dd}`;
      const today    = new Date(); today.setHours(0, 0, 0, 0);
      const diffDays = Math.ceil((end - today) / 86400000);
      badge.style.display = '';
      if (diffDays < 0)        { badge.className = 'end-date-badge badge-expired';  badge.textContent = 'Expired ' + Math.abs(diffDays) + ' day(s) ago'; }
      else if (diffDays <= 90) { badge.className = 'end-date-badge badge-expiring'; badge.textContent = '⚠ Expiring in ' + diffDays + ' day(s)'; }
      else                     { badge.className = 'end-date-badge badge-ok';       badge.textContent = Math.floor(diffDays / 30) + ' month(s) remaining'; }
    }
