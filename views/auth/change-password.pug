doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Change Password — Staff Management System
    link(rel="stylesheet" href="/css/style.css")
    link(rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css")

  body.auth-body
    .auth-wrapper
      .auth-card.auth-card-wide
        .auth-header
          .auth-logo.auth-logo-warning
            i.fas.fa-key
          h1 Change Your Password
          if isFirstLogin
            p.auth-subtitle.text-warning
              i.fas.fa-exclamation-triangle
              | &nbsp; First login — you must set a new password to continue.
          else
            p.auth-subtitle Change your account password

        if errors && errors.length
          .alert.alert-error
            i.fas.fa-exclamation-circle
            ul.error-list
              each err in errors
                li= err

        form.auth-form(action="/auth/change-password" method="POST")
          .form-group
            label.form-label
              i.fas.fa-lock
              | &nbsp; Current Password *
            .input-password-wrap
              input.form-input#cp1(type="password" name="currentPassword" placeholder="Enter current password" required)
              button.toggle-pw(type="button" onclick="togglePw('cp1',this)")
                i.fas.fa-eye

          .pw-divider
            span New Password

          .form-group
            label.form-label
              i.fas.fa-lock-open
              | &nbsp; New Password *
            .input-password-wrap
              input.form-input#cp2(type="password" name="newPassword" placeholder="Min 8 characters" required minlength="8" oninput="checkStrength(this)")
              button.toggle-pw(type="button" onclick="togglePw('cp2',this)")
                i.fas.fa-eye
            .pw-strength#pwStrength(style="display:none")
              .pw-bar#pwBar
              span#pwLabel

          .form-group
            label.form-label
              i.fas.fa-check-circle
              | &nbsp; Confirm New Password *
            .input-password-wrap
              input.form-input#cp3(type="password" name="confirmPassword" placeholder="Repeat new password" required)
              button.toggle-pw(type="button" onclick="togglePw('cp3',this)")
                i.fas.fa-eye

          .pw-rules
            p Password requirements:
            ul
              li At least 8 characters
              li Different from your current password

          .form-actions-auth
            if !isFirstLogin
              a.btn.btn-outline(href="/staff") Cancel
            button.btn.btn-primary(type="submit")
              i.fas.fa-save
              | &nbsp; Change Password

        .auth-footer
          p Staff Management System

  script.
    function togglePw(id, btn) {
      const inp = document.getElementById(id);
      const isText = inp.type === 'text';
      inp.type = isText ? 'password' : 'text';
      btn.querySelector('i').className = isText ? 'fas fa-eye' : 'fas fa-eye-slash';
    }

    function checkStrength(inp) {
      const val = inp.value;
      const bar = document.getElementById('pwBar');
      const lbl = document.getElementById('pwLabel');
      const wrap = document.getElementById('pwStrength');
      wrap.style.display = val.length ? 'block' : 'none';

      let score = 0;
      if (val.length >= 8) score++;
      if (/[A-Z]/.test(val)) score++;
      if (/[0-9]/.test(val)) score++;
      if (/[^A-Za-z0-9]/.test(val)) score++;

      const levels = ['Weak','Fair','Good','Strong'];
      const colors = ['#dc2626','#d97706','#2563eb','#059669'];
      bar.style.width = (score * 25) + '%';
      bar.style.background = colors[score - 1] || '#dc2626';
      lbl.textContent = levels[score - 1] || 'Very Weak';
      lbl.style.color = colors[score - 1] || '#dc2626';
    }
